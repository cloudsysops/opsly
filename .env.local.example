# Copia a .env.local (no commitear): cp .env.local.example .env.local
#
# Supabase local — API URL para el navegador: usa la IP LAN de la Mac 2011 si entras
# desde la Mac 2020. Los scripts local-setup.sh rellenan claves desde `supabase status`.
# Para tráfico server-side dentro de Docker: host.docker.internal apunta al host Colima.

NEXT_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-de-supabase-start>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-de-supabase-start>
SUPABASE_URL=http://host.docker.internal:54321

# Platform
PLATFORM_DOMAIN=opsly.local
PLATFORM_ADMIN_TOKEN=local-dev-token-insecure
PLATFORM_TENANTS_DIR=/opt/opsly/tenants
TENANTS_PATH=/tmp/opsly/tenants
TEMPLATE_PATH=/opt/opsly/templates/docker-compose.tenant.yml.tpl

# Redis (servicio "redis" en docker-compose.local.yml)
REDIS_PASSWORD=localredis
REDIS_URL=redis://:localredis@redis:6379/0

# Stripe TEST
STRIPE_SECRET_KEY=sk_test_REEMPLAZAR
STRIPE_WEBHOOK_SECRET=whsec_REEMPLAZAR
STRIPE_PRICE_STARTUP=price_REEMPLAZAR
STRIPE_PRICE_BUSINESS=price_REEMPLAZAR
STRIPE_PRICE_ENTERPRISE=price_REEMPLAZAR

# Doppler (opcional en local)
DOPPLER_TOKEN=
DOPPLER_TEMPLATE_PROJECT=tenant-template

# Email (opcional en local)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=dev@opsly.local

# Notificaciones (opcional en local)
DISCORD_WEBHOOK_URL=

# Admin app (navegador resuelve api.opsly.local vía /etc/hosts)
NEXT_PUBLIC_API_URL=http://api.opsly.local
NEXT_PUBLIC_PLATFORM_ADMIN_TOKEN=local-dev-token-insecure
NEXT_PUBLIC_PLATFORM_DOMAIN=opsly.local
NEXT_PUBLIC_APP_VERSION=0.0.0-local

# AWS/S3 (MinIO u otro S3-compatible en el host; opcional)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET=opsly-backups
S3_PREFIX=opsly/backups
AWS_ENDPOINT_URL=http://host.docker.internal:9000
