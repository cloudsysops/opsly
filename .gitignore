# --- Terraform (infra/terraform/) ---
# .terraform/ — plugins y metadata del proveedor (regenerable con terraform init).
# terraform.tfstate / *.backup — estado con IDs y a veces datos sensibles; por máquina.
# *.tfvars — suele usarse para secretos locales; no commitear (usar TF_VAR_* / Doppler).
# .terraform.lock.hcl — NO ignorar: fija versiones del proveedor; debe versionarse en git.
.terraform/
terraform.tfstate
terraform.tfstate.backup
*.tfvars
infra/terraform/tfplan

# Cursor prompt monitor (VPS/local runtime log)
logs/

# Supabase CLI local link metadata (regenerable)
supabase/.temp/

# Playwright (apps/portal)
apps/portal/test-results/
apps/portal/playwright-report/

# Obsidian — ignore runtime/personal state
docs/.obsidian/cache
docs/.obsidian/workspace
docs/.obsidian/workspace.json
docs/.obsidian/plugins/recent-files-obsidian/data.json

# Keep config + plugin settings tracked
!docs/.obsidian/app.json
!docs/.obsidian/vault.json
!docs/.obsidian/core-plugins.json
!docs/.obsidian/community-plugins.json
!docs/.obsidian/templates/
!docs/.obsidian/hotkeys.json
!docs/.obsidian/file-index.json
!docs/.obsidian/plugins/obsidian-git/data.json
