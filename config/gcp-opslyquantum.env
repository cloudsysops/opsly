# GCP — plantilla para proyecto opslyquantum (sin secretos reales en git: copiar a config/gcp.env y rellenar).
# Prioridad: si existe config/gcp.env, los scripts lo cargan antes que este archivo.

# --- Proyecto GCP ---
GCP_PROJECT_ID=opslyquantum
GCP_INSTANCE_NAME=opsly-failover
GCP_ZONE=us-central1-a
GCP_MACHINE_TYPE=e2-micro

# --- SSH sync (rsync primario → standby) — rellenar con tus hosts Tailscale ---
# SYNC_SSH_PRIMARY=vps-dragon@100.x.x.x
# SYNC_SSH_GCP=opsly@x.x.x.x

# --- Tailscale (clave efímera desde admin; no commitear en gcp.env con valor real si compartes el repo) ---
# TAILSCALE_AUTHKEY=tskey-auth-REEMPLAZAR

# --- Cloudflare Load Balancing (CF_* se mapean en configure-cloudflare-lb.sh) ---
# CF_API_TOKEN=
# CF_ACCOUNT_ID=   # mismo uso que CLOUDFLARE_ACCOUNT_ID
# CLOUDFLARE_ACCOUNT_ID=
# CF_ZONE_ID=
CLOUDFLARE_POOL_ID=
PRIMARY_ORIGIN_ADDRESS=
FAILOVER_ORIGIN_ADDRESS=
PRIMARY_ORIGIN_NAME=primary-do
FAILOVER_ORIGIN_NAME=failover-gcp
PRIMARY_WEIGHT=1
FAILOVER_WEIGHT=0

# --- Alertas / health (dominio de staging en opsly; ajustar si cambia) ---
# DISCORD_WEBHOOK_URL=
# HEALTH_URL=https://api.${PLATFORM_DOMAIN}/api/health
# PLATFORM_DOMAIN=ops.smiletripcare.com
