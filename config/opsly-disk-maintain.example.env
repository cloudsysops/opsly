# Copiar a:
#   VPS (system):   sudo cp config/opsly-disk-maintain.example.env /etc/default/opsly-disk-maintain
#   Worker (user):  mkdir -p ~/.config/opsly && cp … ~/.config/opsly/disk-maintain.env
#
# Ajustar peers: SSH por clave (Tailscale) en ambas direcciones si quieres fan-out bidireccional.

# Porcentaje máximo observado en filesystems locales (-l); si >= umbral, se dispara mantenimiento.
OPSLY_DISK_THRESHOLD=89

# Lista separada por espacios: user@host (Tailscale recomendado).
# Ejemplo VPS → worker Mac:
# OPSLY_MAINTAIN_PEERS="opslyquantum@100.80.41.29"
# Ejemplo worker → VPS:
# OPSLY_MAINTAIN_PEERS="vps-dragon@100.120.151.91"

OPSLY_MAINTAIN_PEERS=""

# No repetir fan-out completo antes de N segundos (evita tormenta si el disco sigue alto).
OPSLY_DISK_MAINTAIN_COOLDOWN_SEC=3600

# Opcional: fichero de marca para cooldown (default ~/.cache/opsly/disk-maintain.last)
# OPSLY_DISK_MAINTAIN_STAMP=/var/lib/opsly/disk-maintain.last
