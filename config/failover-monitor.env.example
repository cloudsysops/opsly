# Copiar a config/failover-monitor.env (gitignored) o exportar en systemd EnvironmentFile.
# Intervalo entre comprobaciones (segundos)
# CHECK_INTERVAL=30
# Fallos de health consecutivos antes de alertar / valorar acción
# MAX_FAILURES=3
# URL pública de health (sin secretos en este archivo)
# HEALTH_URL=https://api.ops.smiletripcare.com/api/health
# VPS — solo Tailscale
# PRIMARY_TAILSCALE_HOST=100.120.151.91
# PRIMARY_SSH_USER=vps-dragon
# Discord — preferir variable de entorno ya usada en Opsly
# DISCORD_WEBHOOK_URL=
# IPs u hostnames de origen en el pool de Cloudflare (misma cuenta que el LB)
# PRIMARY_ORIGIN_ADDRESS=
# FAILOVER_ORIGIN_ADDRESS=
# PRIMARY_ORIGIN_NAME=primary
# FAILOVER_ORIGIN_NAME=failover
# Failover automático vía API Cloudflare (requiere segundo origen + LB reales). Por defecto desactivado.
# FAILOVER_AUTO_CF=false
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_POOL_ID=
