# Copiar a config/worker-tailscale.env (gitignored) o exportar en el shell.
#
# Nombre del nodo del worker en `tailscale status` (columna del nombre, sin dominio).
# WORKER_TAILSCALE_NAME=opsly-worker
WORKER_USER=opslyquantum

# Opcional: FQDN MagicDNS completo (anula la construcción automática nombre.suffix.ts.net)
# OPSLY_WORKER_HOSTNAME=opsly-worker.taile4fe40.ts.net

# Opcional: forzar destino ssh (alias de ~/.ssh/config); anula FQDN automático
# WORKER_SSH=opsly-worker
