{
  "name": "@intcloudsysops/ml",
  "version": "1.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./feedback-decision-engine": {
      "types": "./src/feedback-decision-engine.ts",
      "import": "./dist/src/feedback-decision-engine.js",
      "default": "./dist/src/feedback-decision-engine.js"
    },
    "./feedback-decision-engine-runtime": {
      "types": "./src/feedback-decision-engine.ts",
      "import": "./dist/src/feedback-decision-engine.js",
      "default": "./dist/src/feedback-decision-engine.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@intcloudsysops/llm-gateway": "^1.0.0",
    "@supabase/supabase-js": "^2.56.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.12",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
