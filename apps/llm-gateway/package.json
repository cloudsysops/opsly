{
  "name": "@intcloudsysops/llm-gateway",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "test": "LLM_BATCH_WINDOW_SCALE=0 vitest run",
    "type-check": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js",
      "types": "./src/index.ts"
    },
    "./logger": {
      "import": "./dist/src/logger.js",
      "default": "./dist/src/logger.js",
      "types": "./src/logger.ts"
    },
    "./cache": {
      "import": "./dist/src/cache.js",
      "default": "./dist/src/cache.js",
      "types": "./src/cache.ts"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "@supabase/supabase-js": "^2.56.1",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.12",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
