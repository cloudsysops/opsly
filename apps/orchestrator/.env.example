# Orchestrator — copiar a .env local o cargar vía Doppler (no commitear secretos).

# Redis (BullMQ / PubSub OAR)
# REDIS_URL=redis://127.0.0.1:6379

# Langfuse (X-Ray / trazas OAR — doble escritura con Redis)
# Self-hosted: URL alcanzable desde el proceso del orchestrator (red Docker o Tailscale).
LANGFUSE_PUBLIC_KEY=pk-xxxxx
LANGFUSE_SECRET_KEY=sk-xxxxx
# Host base de la API Langfuse (v3 SDK usa baseUrl). Ejemplo en VPS: servicio interno compose.
LANGFUSE_HOST=http://langfuse:3000
