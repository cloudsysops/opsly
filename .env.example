# ── Platform ──────────────────────────────
# Dominio raíz de la plataforma (sin https://)
PLATFORM_DOMAIN=yourdomain.com
# Alias usado por código legado (orchestrator); si no existe, se usa PLATFORM_DOMAIN
PLATFORM_BASE_DOMAIN=yourdomain.com
# Versión expuesta en GET /api/health
OPSLY_VERSION=0.1.0
# Bearer para API de administración y scripts (mín. 32 caracteres recomendado)
PLATFORM_ADMIN_TOKEN=change-me-32-chars-minimum
# Imagen publicada del servicio API (Compose)
APP_IMAGE=ghcr.io/your-org/intcloudsysops-api:latest
ADMIN_APP_IMAGE=ghcr.io/your-org/intcloudsysops-admin:latest

# ── Supabase ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Algunos scripts usan SUPABASE_URL (mismo valor que NEXT_PUBLIC_SUPABASE_URL)
SUPABASE_URL=https://xxxx.supabase.co

# ── Stripe ────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTUP=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...
# apps/web (checkout) — IDs de precio Stripe
STRIPE_PRICE_ID_STARTUP=price_...
STRIPE_PRICE_ID_BUSINESS=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...
STRIPE_PRICE_ID_DEMO=price_...

# ── Redis ─────────────────────────────────
REDIS_URL=redis://:password@localhost:6379
REDIS_PASSWORD=change-me

# ── Docker / Tenants ──────────────────────
PLATFORM_TENANTS_HOST_PATH=/opt/opsly/tenants
# Ruta base donde el API escribe docker-compose.yml por tenant (dentro del contenedor)
PLATFORM_TENANTS_DIR=/opt/opsly/tenants
TENANTS_PATH=/opt/opsly/tenants
TEMPLATE_PATH=/opt/opsly/templates/docker-compose.tenant.yml.tpl
TRAEFIK_NETWORK=traefik-public
# Usuario HTTP básico por defecto para n8n en plantilla tenant
N8N_BASIC_AUTH_USER=admin

# ── Traefik ───────────────────────────────
ACME_EMAIL=admin@yourdomain.com
# htpasswd; en Compose escapa $ como $$
TRAEFIK_DASHBOARD_BASIC_AUTH_USERS=admin:$$apr1$$...

# ── Doppler ───────────────────────────────
DOPPLER_TOKEN=dp.st.xxx
DOPPLER_TEMPLATE_PROJECT=tenant-template
# Opcionales: detección de CLI/config en apps/api/lib/doppler
DOPPLER_PROJECT=your-project
DOPPLER_ENVIRONMENT=prd
DOPPLER_CONFIG=prd

# ── Notifications ─────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_BOT_AVATAR_URL=https://...

# ── Email ─────────────────────────────────
RESEND_API_KEY=re_...
# apps/api acepta cualquiera de las dos (preferencia RESEND_FROM_EMAIL)
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_ADDRESS=noreply@yourdomain.com

# ── Backups ───────────────────────────────
DB_CONNECTION_STRING=postgresql://user:pass@host:5432/postgres
S3_BUCKET=your-backup-bucket
S3_PREFIX=opsly/backups
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# ── Admin Dashboard ───────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_PLATFORM_ADMIN_TOKEN=same-as-PLATFORM_ADMIN_TOKEN
NEXT_PUBLIC_PLATFORM_DOMAIN=yourdomain.com
NEXT_PUBLIC_APP_VERSION=0.1.0
# scripts/cleanup-demos.sh — URL base del API (p. ej. https://api.yourdomain.com)
NEXT_PUBLIC_APP_URL=https://api.yourdomain.com
# Admin settings UI (opcional)
NEXT_PUBLIC_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
NEXT_PUBLIC_STRIPE_WEBHOOK_CONFIGURED=false
