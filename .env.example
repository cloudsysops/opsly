# Opsly — plantilla unificada de variables (Doppler `prd` / VPS / local).
# Copiar a `.env` o `.env.local` según tu flujo: `cp .env.example .env`
# No commitear valores reales.

# ============================================
# PLATAFORMA CORE
# ============================================

# Dominio base de la plataforma (sin https://), ej. ops.smiletripcare.com
PLATFORM_DOMAIN=

# Dominio base de servicios tenant (n8n-<slug>, uptime-<slug>).
# Si está vacío, usa PLATFORM_DOMAIN.
TENANT_BASE_DOMAIN=

# Slug sintético para jobs internos (Hive, notify de arranque). Por defecto: platform
OPSLY_INTERNAL_TENANT_SLUG=

# Alias legado para orquestador; si vacío suele usarse PLATFORM_DOMAIN
PLATFORM_BASE_DOMAIN=

# Versión expuesta en GET /api/health
OPSLY_VERSION=0.1.0

# Token de administración para scripts y API interna (SECRETO). Mín. ~32 caracteres en prod.
# Mantener en Doppler; no commitear valores reales.
PLATFORM_ADMIN_TOKEN=

# Imagen GHCR del API (Compose / deploy)
APP_IMAGE=ghcr.io/your-org/intcloudsysops-api:latest

# Imagen GHCR del admin Next (Compose / deploy)
ADMIN_APP_IMAGE=ghcr.io/your-org/intcloudsysops-admin:latest

# VPS staging (/opt/opsly-staging): usar tags :staging en todas las imágenes Opsly (CI push rama staging).
# PORTAL_APP_IMAGE=.../intcloudsysops-portal:staging
# MCP_IMAGE=.../intcloudsysops-mcp:staging
# LLM_GATEWAY_IMAGE=.../intcloudsysops-llm-gateway:staging
# ORCHESTRATOR_IMAGE=.../intcloudsysops-orchestrator:staging
# CONTEXT_BUILDER_IMAGE=.../intcloudsysops-context-builder:staging

# Ruta en el host VPS donde persisten volúmenes/datos de tenants (si aplica)
PLATFORM_TENANTS_HOST_PATH=/opt/opsly/runtime/tenants

# Directorio donde el API escribe compose por tenant (ruta dentro del contenedor o host según deploy)
PLATFORM_TENANTS_DIR=/opt/opsly/runtime/tenants

# Alias de ruta usado por scripts de tenant
TENANTS_PATH=/opt/opsly/runtime/tenants

# Plantilla docker-compose por tenant
TEMPLATE_PATH=/opt/opsly/templates/docker-compose.tenant.yml.tpl

# Ruta absoluta al repositorio de Opsly (para que el agente pueda leer archivos)
# En Docker Compose se mapea generalmente a /opt/opsly
OPSLY_REPO_ROOT=/opt/opsly

# Red Docker a la que se anexan servicios Traefik
TRAEFIK_NETWORK=traefik-public

# Usuario HTTP básico por defecto para n8n en plantilla tenant
N8N_BASIC_AUTH_USER=admin

# ============================================
# SUPABASE (Auth & DB)
# ============================================

# URL del proyecto Supabase (navegador / Next)
NEXT_PUBLIC_SUPABASE_URL=

# Misma URL para código server-side que usa SUPABASE_URL
SUPABASE_URL=

# Clave anon (pública, solo para cliente con RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role Key (SECRETO; solo backend / scripts con privilegio)
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# STRIPE (Billing)
# ============================================

# Con NODE_ENV=production el runtime usa claves LIVE; si no, TEST.
# Live — solo Doppler prod / dashboard Stripe modo Live
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Test — desarrollo y CI (NODE_ENV ≠ production)
STRIPE_TEST_SECRET_KEY=
STRIPE_WEBHOOK_SECRET_TEST=

# Clave publicable para Checkout / Elements (pk_live_ o pk_test_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# IDs de precio (alias legado en apps/web)
STRIPE_PRICE_STARTUP=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=

# IDs de precio con prefijo STRIPE_PRICE_ID_* (apps/api / checkout)
STRIPE_PRICE_ID_STARTUP=
STRIPE_PRICE_ID_BUSINESS=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_PRICE_ID_DEMO=

# ============================================
# REDIS (Colas & Caché)
# ============================================

# URL completa incl. auth, ej. redis://:password@host:6379/0
REDIS_URL=

# Contraseña si el compose la inyecta por separado
REDIS_PASSWORD=

# ============================================
# MONITOREO PLATAFORMA (Prometheus en compose infra)
# ============================================

# URL base del Prometheus que ve el contenedor API (default: servicio `prometheus` en red internal).
# Solo override si Prometheus corre fuera del compose (ej. host.docker.internal:9090).
PROMETHEUS_BASE_URL=http://prometheus:9090

# Puerto en el host VPS para depuración (Prometheus UI); default 9090 en 127.0.0.1.
# PROMETHEUS_HOST_PORT=9090

# ============================================
# OPENCLAW / AI (opcional — Fase 4+)
# ============================================

ANTHROPIC_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=nemotron-3-nano:4b
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OPENROUTER_HTTP_REFERER=https://opsly.local
LLM_CACHE_TTL_SECONDS=7200
LLM_GATEWAY_PORT=3010
# PAT GitHub (API REST: ACTIVE-PROMPT, issues). Preferido: GITHUB_TOKEN (alineado con `gh` / CLI).
GITHUB_TOKEN=
# Legado (nombre antiguo cuando n8n escribía vía API); se usa si GITHUB_TOKEN está vacío.
GITHUB_TOKEN_N8N=
# n8n API (opcional) — cliente MCP externo `n8n-mcp` (Cursor / contenedor). Ver docs/02-tools/N8N-MCP-INTEGRATION.md
# N8N_API_URL=https://n8n-<tenant-slug>.<PLATFORM_DOMAIN>/
# N8N_API_KEY=
# Token para proteger n8n-mcp en modo HTTP (overlay infra/docker-compose.n8n-mcp.yml)
# N8N_MCP_AUTH_TOKEN=

N8N_WEBHOOK_URL=
# Secreto compartido header X-Opsly-Secret (Discord→GitHub). Preferido en Doppler.
# Nombre antiguo del mismo valor en algunos Doppler: GITHUB_N8N — migrar a N8N_WEBHOOK_SECRET_GH.
N8N_WEBHOOK_SECRET_GH=
# Legado; los scripts resuelven GH → este → GITHUB_N8N.
N8N_WEBHOOK_SECRET=

# Jcode (agente de código autónomo; worker jcode_execution)
JCODE_API_KEY=
JCODE_MODEL=
JCODE_PROVIDER=

# JSON service account (una línea o usar *_FILE abajo)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_FILE=

# OAuth usuario (ADC / JSON con refresh_token) — drive-sync, Mi unidad
GOOGLE_USER_CREDENTIALS_JSON=
GOOGLE_USER_CREDENTIALS_JSON_FILE=
GOOGLE_AUTH_STRATEGY=user_first

# MCP — URL pública del servidor MCP (OAuth discovery)
MCP_PUBLIC_URL=
MCP_JWT_SECRET=
# stdio = protocolo MCP local (Cursor); vacío en Docker (HTTP + OAuth en PORT)
# MCP_TRANSPORT=stdio

# Google Cloud (BigQuery / Vertex — fase 10+)
GOOGLE_CLOUD_PROJECT_ID=
# Alias opcional (orquestador Vertex client)
GCLOUD_PROJECT_ID=
GCLOUD_REGION=
# JSON en una línea (mismo uso que GOOGLE_SERVICE_ACCOUNT_JSON)
GCLOUD_SERVICE_ACCOUNT_JSON=
BIGQUERY_DATASET=
VERTEX_AI_REGION=

# Vertex AI — embeddings en Approval Gate (orquestador)
# Requiere credenciales GCP + migraciones 0026/0027
VERTEX_AI_EMBED_ENABLED=false
VERTEX_AI_EMBEDDING_MODEL=text-embedding-004

# ============================================
# INFRA & BACKUPS (opcional)
# ============================================

# Traefik / Let's Encrypt
ACME_EMAIL=
TRAEFIK_DASHBOARD_BASIC_AUTH_USERS=

# Doppler CLI / proyectos
DOPPLER_TOKEN=
DOPPLER_TEMPLATE_PROJECT=tenant-template
DOPPLER_PROJECT=
DOPPLER_ENVIRONMENT=prd
DOPPLER_CONFIG=prd

# Cloudflare — API token DNS (Traefik dnsChallenge; proxy ON en dashboard)
CF_DNS_API_TOKEN=

# Postgres directo para backups / scripts (no usar en cliente web)
DB_CONNECTION_STRING=

# S3 o compatible (MinIO en local) — backups y objetos
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=
S3_BUCKET=
S3_PREFIX=opsly/backups

# ============================================
# COMUNICACIÓN
# ============================================

RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_ADDRESS=
DISCORD_WEBHOOK_URL=
DISCORD_BOT_AVATAR_URL=

# Local Services — webhooks n8n (HMAC-SHA256 del body raw; cabecera X-Opsly-Signature: sha256=<hex>)
# Por tenant (slug normalizado a MAYÚS, no alfanuméricos → _): LOCAL_SERVICES_WEBHOOK_SECRET_LOCAL_SERVICES=
LOCAL_SERVICES_WEBHOOK_SECRET=

# ============================================
# CLIENTE ADMIN / WEB / PORTAL (Next.js)
# ============================================

# URL base del API visto desde el navegador (admin/portal/web)
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_WEB_URL=
NEXT_PUBLIC_PORTAL_URL=

# Dominio público de la plataforma (sin esquema)
NEXT_PUBLIC_PLATFORM_DOMAIN=

NEXT_PUBLIC_APP_VERSION=0.1.0

# Admin: mostrar enlace Discord / estado webhook Stripe en UI (opcional)
NEXT_PUBLIC_DISCORD_WEBHOOK_URL=
NEXT_PUBLIC_STRIPE_WEBHOOK_CONFIGURED=false
# DeepSeek V4 via LLM Gateway (OpenAI-compatible; no direct app calls)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# Redis Namespace Isolation - Per-Tenant Configuration
# ====================================================

# Context Builder - Redis namespace configuration
CONTEXT_BUILDER_REDIS_NAMESPACE=ctx

# LLM Gateway - Tenant-aware Redis caching
LLM_GATEWAY_TENANT_AWARE=false
LLM_GATEWAY_REDIS_NAMESPACE=llm

