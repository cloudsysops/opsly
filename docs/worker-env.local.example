# Plantilla para ~/opsly/.env.local en el worker (NO commitear).
# Copiar: cp docs/worker-env.local.example ~/opsly/.env.local  y rellenar con Doppler o valores seguros.
#
# NODE_ENV=development
# WORKER_ID=opslyquantum-worker-01
# OPSLY_ORCHESTRATOR_MODE=worker-enabled
#
# Obligatorio para BullMQ — misma URL que en entorno de plataforma (Doppler ops-intcloudsysops / prd):
# REDIS_URL=redis://:PASSWORD@HOST:6379
#
# URL del gateway en el VPS (Tailscale o endpoint alcanzable desde el worker):
# LLM_GATEWAY_URL=http://<tailscale-vps-ip>:3010
#
# Autonomía + Ollama local (ver scripts/ensure-ollama-local.sh, docs/AGENTS-AUTONOMOUS-RUNBOOK.md):
# OPSLY_ENSURE_OLLAMA=1
# OPSLY_FAIL_WITHOUT_OLLAMA=0
# OLLAMA_BASE_URL=http://127.0.0.1:11434
#
# Defaults conservadores para Mac 2011 / worker plane:
# ORCHESTRATOR_CURSOR_CONCURRENCY=1
# ORCHESTRATOR_OLLAMA_CONCURRENCY=1
# ORCHESTRATOR_N8N_CONCURRENCY=1
# ORCHESTRATOR_DRIVE_CONCURRENCY=1
# ORCHESTRATOR_NOTIFY_CONCURRENCY=2
#
# API pública (solo si el orchestrator la necesita):
# OPSLY_API_INTERNAL_URL=https://api.ops.smiletripcare.com
#
# No pegues SUPABASE_SERVICE_ROLE_KEY en chats; carga desde Doppler o archivo local privado.
