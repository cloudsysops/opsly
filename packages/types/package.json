{
  "name": "@intcloudsysops/types",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./approval": {
      "types": "./src/approval.ts",
      "import": "./dist/approval.js",
      "require": "./dist/approval.js",
      "default": "./dist/approval.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}
