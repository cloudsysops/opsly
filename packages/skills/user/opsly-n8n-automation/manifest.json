{
  "name": "opsly-n8n-automation",
  "version": "1.0.0",
  "description": "Expert n8n automation for Opsly platform — autonomous agents, workflow optimization, income generation",
  "trigger": [
    "n8n autonomous agent",
    "workflow automation n8n",
    "n8n bitcoin income",
    "automate platform n8n",
    "n8n agent expert",
    "produce bitcoin n8n",
    "n8n monetization",
    "autonomous n8n workflows"
  ],
  "inputSchema": {
    "type": "object",
    "properties": {
      "mode": { "type": "string", "enum": ["expert", "income", "optimization"] },
      "tenant_slug": { "type": "string" },
      "strategy": { "type": "string", "enum": ["bitcoin-production", "cost-optimization", "auto-deploy"] },
      "budget_usd": { "type": "number", "minimum": 0 }
    },
    "required": ["mode", "tenant_slug"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "workflows_created": { "type": "number" },
      "income_btc": { "type": "number" },
      "cost_reduction_pct": { "type": "number" },
      "improvements_committed": { "type": "number" }
    }
  }
}
