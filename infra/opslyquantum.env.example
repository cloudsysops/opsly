# Copiar a infra/opslyquantum.env (no commitear valores reales).
#   cp infra/opslyquantum.env.example infra/opslyquantum.env
#
# Worker Linux opslyquantum — stack Docker local (Ollama, Redis, Postgres, perfiles opcionales).

# Ollama
OLLAMA_ORIGINS=*

# Postgres
POSTGRES_DB=opsly_local
POSTGRES_USER=opsly
POSTGRES_PASSWORD=change_me_strong_password

# Redis
REDIS_MAXMEMORY=2gb

# n8n (perfil automation)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n
N8N_WEBHOOK_URL=http://localhost:5679/

# Grafana (perfil monitoring)
GRAFANA_ADMIN_PASSWORD=change_me_grafana
GRAFANA_ROOT_URL=http://localhost:3003/
