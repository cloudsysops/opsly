#!/usr/bin/env sh
set -e
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

# Fuente única de verdad para hooks de pre-commit.
if [ -x "$ROOT/.githooks/pre-commit" ]; then
  exec "$ROOT/.githooks/pre-commit" "$@"
fi

echo "husky pre-commit: .githooks/pre-commit no encontrado o sin permisos" >&2
exit 1
