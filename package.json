{
  "name": "intcloudsysops",
  "private": true,
  "packageManager": "npm@10.5.0",
  "workspaces": [
    "apps/*",
    "apps/agents/notebooklm",
    "skills/manifest",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "turbo type-check",
    "update-state": "node scripts/update-state.js",
    "sync-agents": "bash scripts/update-agents.sh",
    "validate-context": "python3 -m json.tool context/system_state.json > /dev/null",
    "validate-openapi": "node scripts/ci/validate-openapi.mjs",
    "validate-structure": "node scripts/validate-repo-structure.mjs",
    "index-knowledge": "bash scripts/index-knowledge.sh",
    "validate-skills": "npm run validate-skills --prefix skills/manifest",
    "test-skills-manifest": "npm test --prefix skills/manifest",
    "skills:list": "node scripts/load-skills.js list",
    "skills:bootstrap": "node scripts/load-skills.js bootstrap",
    "skills:sync:external": "bash scripts/sync-skills-external.sh",
    "knowledge:archive:ingest": "node scripts/archive-to-obsidian.mjs",
    "knowledge:archive:ingest:all": "bash scripts/archive-ingest-all-domains.sh",
    "agents:hooks:bootstrap:internal": "bash scripts/agent-hooks.sh bootstrap --mode internal",
    "agents:hooks:bootstrap:external": "bash scripts/agent-hooks.sh bootstrap --mode external",
    "agents:hooks:post-commit": "bash scripts/agent-hooks.sh post-commit",
    "opsly:ensure-ollama": "bash scripts/ensure-ollama-local.sh",
    "opsly:vps-ssh:ensure-key": "bash scripts/vps-ssh-ensure-key.sh",
    "opsly:vps-ssh:verify": "bash scripts/vps-ssh-verify.sh",
    "opsly:vps-ssh:bootstrap": "bash scripts/vps-ssh-bootstrap-from-admin.sh",
    "opsly:drive:ensure-layout": "python3 scripts/opsly_drive_automation.py ensure-layout",
    "opsly:drive:upload-tenant-onboarding": "python3 scripts/opsly_drive_automation.py upload-tenant-pack",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "test:e2e": "turbo run test:e2e",
    "dev:notion-mcp": "doppler run --project ops-intcloudsysops --config prd -- npm run dev --workspace=@intcloudsysops/notion-mcp",
    "start:notion-mcp": "doppler run --project ops-intcloudsysops --config prd -- npm run start --workspace=@intcloudsysops/notion-mcp",
    "enqueue-test-job": "tsx --tsconfig scripts/tsconfig.enqueue.json scripts/enqueue-test-job.ts",
    "docs:sync": "node scripts/sync-docs.js && node scripts/generate-sprint-tracking.js && node scripts/generate-agents-assignments.js",
    "docs:watch": "nodemon --watch docs/implementation/status.yaml --exec \"npm run docs:sync\"",
    "test:docs": "bash scripts/test-sync-docs.sh",
    "notion:fetch": "node scripts/notion-to-yaml.js",
    "notion:push": "node scripts/yaml-to-notion.js",
    "notion:sync": "npm run notion:fetch && npm run docs:sync",
    "notion:validate": "node scripts/validate-notion-schema.js",
    "github:sync-issues": "node scripts/notion-to-github-issues.js",
    "sprint:burndown": "node scripts/update-sprint-burndown.js",
    "agents:status": "node scripts/generate-agents-assignments.js && (command -v cat >/dev/null && cat docs/AGENTS-ASSIGNMENTS.md || true)",
    "test:notion": "bash scripts/test-notion.sh",
    "evolution:run": "node apps/ai-evolution/src/index.js",
    "evolution:analyze": "node apps/ai-evolution/src/index.js analyze",
    "evolution:plan": "node apps/ai-evolution/src/index.js plan",
    "evolution:implement": "node apps/ai-evolution/src/index.js implement",
    "evolution:validate": "node apps/ai-evolution/src/index.js validate",
    "evolution:deploy": "node apps/ai-evolution/src/index.js deploy",
    "evolution:feedback": "node apps/ai-evolution/src/index.js feedback",
    "evolution:full": "npm run evolution:analyze && npm run evolution:plan && npm run evolution:validate && npm run evolution:deploy",
    "sync:all": "npm run docs:sync && node scripts/sync-all-orchestrator.js",
    "hermes:tick": "npm run hermes --workspace=@intcloudsysops/orchestrator -- tick",
    "hermes:status": "npm run hermes --workspace=@intcloudsysops/orchestrator -- status",
    "docs:code-snapshots": "node scripts/generate-code-snapshots.mjs",
    "docs:to-notebooklm": "node scripts/docs-to-notebooklm.mjs",
    "notebooklm:sync": "npm run docs:code-snapshots && npm run docs:to-notebooklm",
    "notebooklm:query": "node scripts/query-notebooklm.mjs",
    "skills:to-notebooklm": "node scripts/skills-to-notebooklm.mjs",
    "notebooklm:full-sync": "npm run notebooklm:sync && npm run skills:to-notebooklm",
    "layer:url": "bash scripts/get-layer-url.sh",
    "layer:tests": "bash scripts/run-layer-tests.sh",
    "layer:deploy": "bash scripts/deploy-layer.sh",
    "superagents:install": "bash scripts/install-superagents-stack.sh",
    "superagents:up": "bash scripts/superagents-up.sh",
    "superagents:doctor": "bash scripts/superagents-doctor.sh",
    "prepare": "husky",
    "commit": "git-cz"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.12",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "bullmq": "^5.58.5",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.0",
    "lint-staged": "^15.5.1",
    "nodemon": "^3.1.9",
    "playwright": "^1.59.1",
    "prettier": "^3.8.2",
    "turbo": "^2.9.6",
    "typescript": "^5.7.3",
    "yaml": "^2.7.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.sh": [
      "bash -n"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@redis/client": "^1.6.1",
    "js-tiktoken": "^1.0.21"
  }
}
