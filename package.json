{
  "name": "intcloudsysops",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/agents/notebooklm",
    "skills/manifest",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "update-state": "node scripts/update-state.js",
    "sync-agents": "bash scripts/update-agents.sh",
    "validate-context": "python3 -m json.tool context/system_state.json > /dev/null",
    "validate-openapi": "node scripts/validate-openapi-yaml.mjs",
    "index-knowledge": "bash scripts/index-knowledge.sh",
    "validate-skills": "npm run validate-skills --prefix skills/manifest",
    "test-skills-manifest": "npm test --prefix skills/manifest",
    "test": "turbo run test",
    "dev:notion-mcp": "doppler run --project ops-intcloudsysops --config prd -- npm run dev --workspace=@intcloudsysops/notion-mcp",
    "start:notion-mcp": "doppler run --project ops-intcloudsysops --config prd -- npm run start --workspace=@intcloudsysops/notion-mcp",
    "enqueue-test-job": "tsx --tsconfig scripts/tsconfig.enqueue.json scripts/enqueue-test-job.ts",
    "docs:sync": "node scripts/sync-docs.js && node scripts/generate-sprint-tracking.js && node scripts/generate-agents-assignments.js",
    "docs:watch": "nodemon --watch docs/implementation/status.yaml --exec \"npm run docs:sync\"",
    "test:docs": "bash scripts/test-sync-docs.sh",
    "notion:fetch": "node scripts/notion-to-yaml.js",
    "notion:push": "node scripts/yaml-to-notion.js",
    "notion:sync": "npm run notion:fetch && npm run docs:sync",
    "notion:validate": "node scripts/validate-notion-schema.js",
    "github:sync-issues": "node scripts/notion-to-github-issues.js",
    "sprint:burndown": "node scripts/update-sprint-burndown.js",
    "agents:status": "node scripts/generate-agents-assignments.js && (command -v cat >/dev/null && cat docs/AGENTS-ASSIGNMENTS.md || true)",
    "test:notion": "bash scripts/test-notion.sh",
    "sync:all": "npm run docs:sync && node scripts/sync-all-orchestrator.js",
    "hermes:tick": "npm run hermes --workspace=@intcloudsysops/orchestrator -- tick",
    "hermes:status": "npm run hermes --workspace=@intcloudsysops/orchestrator -- status",
    "docs:code-snapshots": "node scripts/generate-code-snapshots.mjs",
    "docs:to-notebooklm": "node scripts/docs-to-notebooklm.mjs",
    "notebooklm:sync": "npm run docs:code-snapshots && npm run docs:to-notebooklm",
    "notebooklm:query": "node scripts/query-notebooklm.mjs"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.21.0",
    "@types/node": "^20.19.12",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "bullmq": "^5.58.5",
    "dotenv": "^16.4.7",
    "eslint": "^9.21.0",
    "js-yaml": "^4.1.0",
    "nodemon": "^3.1.9",
    "tsx": "^4.20.5",
    "turbo": "^1.13.4",
    "typescript": "^5.7.3",
    "yaml": "^2.7.0"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/openai": "^1.4.4",
    "langchain": "^1.3.1",
    "llamaindex": "^0.12.1"
  }
}
